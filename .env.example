# Firebase client (public — restricted in Google Cloud Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server only — never expose to client)
# Option A: path to service account JSON file
FIREBASE_ADMIN_CREDENTIALS_PATH=firebase-service-account.json
# Option B: inline JSON (single line)
# FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account",...}

# PayMongo (server only except public key) — use sk_live_* for production
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=

# Set to true only when debugging with PayMongo test keys (shows simulate button)
# NEXT_PUBLIC_ENABLE_PAYMONGO_SIMULATOR=false

# Optional: Cloud Function URL for deposit fulfillment fallback
# FULFILL_DEPOSIT_FUNCTION_URL=

# Resend (server only — transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tradiq.biz
# Comma-separated admin inboxes for bot investment alerts (falls back to super_admin users)
# ADMIN_NOTIFICATION_EMAILS=ops@tradiq.biz,admin@tradiq.biz

# Public app URL (production) — used for referral links when not localhost
NEXT_PUBLIC_APP_URL=https://www.tradiq.biz

# Optional: restrict CORS on fulfillDeposit Cloud Function (comma-separated origins)
# ALLOWED_ORIGINS=https://www.tradiq.biz
