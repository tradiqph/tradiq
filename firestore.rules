rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    function testDepositFulfillmentEnabled() {
      return get(/databases/$(database)/documents/appConfig/platform).data.enableTestDepositFulfillment == true;
    }

    function clientBotSubscribeEnabled() {
      let config = get(/databases/$(database)/documents/appConfig/platform).data;
      return config.enableClientBotSubscribe == true
        || config.enableTestDepositFulfillment == true;
    }

    function clientWithdrawalEnabled() {
      let config = get(/databases/$(database)/documents/appConfig/platform).data;
      return config.enableClientWithdrawals == true
        || config.enableClientBotSubscribe == true
        || config.enableTestDepositFulfillment == true;
    }

    function validNewUserProfile() {
      let data = request.resource.data;
      return data.walletBalance == 0
        && data.depositBalance == 0
        && data.totalDeposited == 0
        && data.totalWithdrawn == 0
        && data.totalEarnings == 0
        && data.role == 'user'
        && (!('securityPinHash' in data) || data.securityPinHash == null)
        && (!('referredBy' in data) || data.referredBy == null)
        && (!('referralNetworkTracked' in data) || data.referralNetworkTracked == false);
    }

    function protectedUserFields() {
      return [
        'walletBalance',
        'depositBalance',
        'totalDeposited',
        'totalWithdrawn',
        'totalEarnings',
        'role',
        'securityPinHash',
        'hasSecurityPin',
        'referredBy',
        'referralCode',
        'referralStats',
        'referralNetworkTracked',
        'signupReferralCode',
        'email',
      ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && validNewUserProfile();
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(protectedUserFields());

      allow update: if isOwner(userId)
        && testDepositFulfillmentEnabled()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletBalance', 'totalDeposited'])
        && request.resource.data.walletBalance == resource.data.walletBalance + request.resource.data.totalDeposited - resource.data.totalDeposited
        && request.resource.data.totalDeposited > resource.data.totalDeposited;

      allow update: if isOwner(userId)
        && clientBotSubscribeEnabled()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletBalance'])
        && request.resource.data.walletBalance < resource.data.walletBalance
        && resource.data.walletBalance - request.resource.data.walletBalance <= 10000;

      allow update: if isOwner(userId)
        && clientWithdrawalEnabled()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletBalance'])
        && request.resource.data.walletBalance < resource.data.walletBalance
        && resource.data.walletBalance - request.resource.data.walletBalance >= 300
        && resource.data.walletBalance - request.resource.data.walletBalance <= 10000;

      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.type == 'deposit'
          && request.resource.data.status == 'pending'
          && request.resource.data.amount is number
          && request.resource.data.amount >= 500
          && request.resource.data.amount <= 10000;
        allow create: if isOwner(userId)
          && clientBotSubscribeEnabled()
          && request.resource.data.type == 'bot_subscribe'
          && request.resource.data.status == 'paid'
          && request.resource.data.amount is number
          && request.resource.data.amount >= 500
          && request.resource.data.amount <= 10000;
        allow create: if isOwner(userId)
          && clientWithdrawalEnabled()
          && request.resource.data.type == 'withdrawal'
          && request.resource.data.status == 'pending'
          && request.resource.data.amount is number
          && request.resource.data.amount >= 300
          && request.resource.data.amount <= 10000;
        allow update: if isOwner(userId)
          && testDepositFulfillmentEnabled()
          && resource.data.type == 'deposit'
          && resource.data.status == 'pending'
          && request.resource.data.status == 'paid'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'subtitle']);
        allow delete: if false;
      }

      match /bots/{botId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && clientBotSubscribeEnabled()
          && request.resource.data.status == 'active'
          && request.resource.data.amount is number
          && request.resource.data.amount >= 500
          && request.resource.data.amount <= 10000
          && request.resource.data.dailyRate == 0.03
          && request.resource.data.termDays == 30
          && request.resource.data.totalAccrued == 0
          && request.resource.data.daysAccrued == 0;
        allow update, delete: if false;
      }

      match /withdrawalAccounts/{accountId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && clientWithdrawalEnabled()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount >= 300
        && request.resource.data.amount <= 10000
        && request.resource.data.processingFee is number
        && request.resource.data.netPayout is number
        && request.resource.data.accountSnapshot is map;
      allow update: if false;
    }

    match /deposits/{depositId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount >= 500
        && request.resource.data.amount <= 10000
        && request.resource.data.paymongoIntentId is string
        && request.resource.data.qrImageUrl is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'paid'
        && testDepositFulfillmentEnabled()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false;
    }

    match /botsCatalog/{botId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /appConfig/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /_meta/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /supportTickets/{ticketId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;

      match /replies/{replyId} {
        allow read: if isAdmin()
          || (isSignedIn()
            && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid);
        allow write: if false;
      }
    }
  }
}
