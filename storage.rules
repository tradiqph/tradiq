rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Support ticket uploads are server-side only (Admin SDK).
    match /support-tickets/{userId}/{fileName} {
      allow read: if false;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
